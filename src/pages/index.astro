---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AiChangedSeo from '../components/AiChangedSeo.astro';
import TrackVisibility from '../components/TrackVisibility.astro';
import Ecosystem from '../components/Ecosystem.astro';
import LocalSearch from '../components/LocalSearch.astro';
import ContentGeneration from '../components/ContentGeneration.astro';
import Pricing from '../components/Pricing.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import CallToAction from '../components/CallToAction.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Rank.ai | AI-Powered SEO Platform & Agency</title>
		<meta name="description" content="Boost Google & AI search rankings with Rank.ai. All-in-one platform or full-service agency to optimize content, track rankings, and dominate AI search." />
	</head>
	<body>
		<Header />
		<main>
			<Hero />
			<HowItWorks />
			<AiChangedSeo />
			<TrackVisibility />
			<Ecosystem />
			<LocalSearch />
			<ContentGeneration />
			<Pricing />
			<BookingCalendar />
			<CallToAction />
		</main>
	</body>
</html>


