---
import '../styles/global.css';
---

<section id="ai-changed-seo" class="ai-changed-seo">
  <div class="container">
    <div class="section-header">
      <div class="section-tag-wrapper">
        <span class="section-tag">📊 HOW RANK.AI WORKS</span>
      </div>
      <h2>AI changed SEO. Rank Higher in Google & AI</h2>
      <p class="section-subtitle">Visibility now depends on traditional signals (content, links, technical) and AI signals (entity coverage, citations, reputation).</p>
    </div>

    <div class="comparison-rows-container">
      
      <!-- Desktop Labels Header -->
      <div class="comparison-row desktop-labels-header">
        <div class="row-info-col"></div> <!-- Empty spacer for left col -->
        <div class="comparison-visuals">
          <div class="cards-comparison-grid">
            <span class="before-marker-label">Before</span>
            <span class="after-marker-label">After</span>
          </div>
        </div>
      </div>
      <!-- Row 1: Dominate Google Search -->
      <div class="comparison-row">
        <!-- Left: description & CTA (transparent column) -->
        <div class="row-info-col">
          <h3 class="row-title">
            <span class="row-title-icon red-icon">
              <!-- Search Target SVG with Spark -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                <circle cx="10" cy="14" r="6"></circle>
                <line x1="21" y1="21" x2="15" y2="15"></line>
                <path d="M17 4l.5 2.5L20 7l-2.5.5L17 10l-.5-2.5L14 7l2.5-.5z" fill="currentColor" stroke="none"></path>
              </svg>
            </span>
            Dominate Google Search
          </h3>
          <p class="row-desc">Stop hiding on page 3. Rank in the top spots where your customers actually click.</p>
          <button class="cta-btn-custom red-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <circle cx="10" cy="14" r="6"></circle>
              <line x1="21" y1="21" x2="15" y2="15"></line>
              <path d="M17 4l.5 2.5L20 7l-2.5.5L17 10l-.5-2.5L14 7l2.5-.5z" fill="currentColor" stroke="none"></path>
            </svg>
            Check Your Rankings
          </button>
        </div>

        <!-- Right: Before/After visuals -->
        <div class="comparison-visuals">

          <div class="cards-comparison-grid">
            <div class="comparison-column">
              <span class="before-marker-label">Before</span>
              <!-- Before Card -->
              <div class="visual-comparison-card before-highlight">
                <div class="serp-results-container">
                  <div class="serp-header">Google results</div>
                  
                  <!-- Competitor ranking high -->
                  <div class="serp-item">
                    <div class="serp-link">
                      www.yourcompetitor.com <span>↗</span>
                    </div>
                  <div class="serp-title">yourcompetitor.com</div>
                  <div class="serp-rating">
                    <span>4.9</span>
                    <span class="stars-rating">★★★★★</span>
                    <span style="color: var(--text-muted); font-weight: 500;">| 72 Reviews</span>
                  </div>
                </div>

                <!-- Divider line -->
                <div class="serp-divider"></div>

                <!-- Your business ranking low & Gauge side-by-side -->
                <div class="serp-split-row">
                  <div class="serp-item highlighted-before">
                    <span class="badge-pill-inline red">Before - Rank #32</span>
                    <div class="serp-link">
                      www.yourbusiness.com <span>↗</span>
                    </div>
                    <div class="serp-title">Your business without RankAI</div>
                    <div class="serp-rating">
                      <span>2.0</span>
                      <span class="stars-rating">★★</span><span class="stars-rating empty">★★★</span>
                      <span style="color: var(--text-muted); font-weight: 500;">| 6 Reviews</span>
                    </div>
                  </div>

                  <!-- Gauge -->
                  <div class="lead-gauge-wrapper compact-gauge">
                    <svg class="gauge-svg" viewBox="0 0 100 50">
                      <path class="gauge-bg" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#f1f5f9" stroke-width="8" stroke-linecap="round"></path>
                      <path class="gauge-fill" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#ef4444" stroke-width="8" stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="59"></path>
                    </svg>
                    <div class="gauge-text">
                      <span class="gauge-value-num" style="color: #ef4444;">53</span>
                      <span class="gauge-label">Before Leads</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            </div>

            <div class="comparison-column">
              <span class="after-marker-label">After</span>
              <!-- After Card -->
              <div class="visual-comparison-card after-highlight">
                <div class="serp-results-container">
                  <div class="serp-header">Google results</div>
                
                <!-- Your business ranking #1 & Gauge side-by-side -->
                <div class="serp-split-row">
                  <div class="serp-item highlighted-after">
                    <span class="badge-pill-inline green">After - Rank #1</span>
                    <div class="serp-link">
                      www.yourbusiness.com <span>↗</span>
                    </div>
                    <div class="serp-title">Your business with RankAI</div>
                    <div class="serp-rating">
                      <span>4.9</span>
                      <span class="stars-rating">★★★★★</span>
                      <span style="color: var(--text-muted); font-weight: 500;">| 120 Reviews</span>
                    </div>
                  </div>

                  <!-- Gauge -->
                  <div class="lead-gauge-wrapper compact-gauge">
                    <svg class="gauge-svg" viewBox="0 0 100 50">
                      <path class="gauge-bg" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#f1f5f9" stroke-width="8" stroke-linecap="round"></path>
                      <path class="gauge-fill" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#10b981" stroke-width="8" stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="6"></path>
                    </svg>
                    <div class="gauge-text">
                      <span class="gauge-value-num" style="color: #10b981;">300</span>
                      <span class="gauge-value-change">+500%</span>
                      <span class="gauge-label">After Leads</span>
                    </div>
                  </div>
                </div>

                <!-- Divider line -->
                <div class="serp-divider"></div>

                <!-- Competitor pushed down -->
                <div class="serp-item">
                  <div class="serp-link">
                    www.yourcompetitor.com <span>↗</span>
                  </div>
                  <div class="serp-title">yourcompetitor.com</div>
                  <div class="serp-rating">
                    <span>4.9</span>
                    <span class="stars-rating">★★★★★</span>
                    <span style="color: var(--text-muted); font-weight: 500;">| 72 Reviews</span>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
      </div>

      <!-- Row 2: Own Your Local Market -->
      <div class="comparison-row">
        <!-- Left: description & CTA (transparent column) -->
        <div class="row-info-col">
          <h3 class="row-title">
            <span class="row-title-icon green-icon">
              <!-- Map Pin SVG with Spark -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
                <path d="M17 2l.3 1.5L19 4l-1.5.3L17 6l-.3-1.5L15 4l1.5-.3z" fill="currentColor" stroke="none"></path>
              </svg>
            </span>
            Own Your Local Market
          </h3>
          <p class="row-desc">Turn your map from red to green. Dominate the local 3-pack where nearby customers search.</p>
          <button class="cta-btn-custom green-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Improve Local Rankings
          </button>
        </div>

        <!-- Right: Before/After visuals -->
        <div class="comparison-visuals">
          <div class="cards-comparison-grid">
            <div class="comparison-column">
              <span class="before-marker-label">Before</span>
              <!-- Before Card -->
              <div class="visual-comparison-card before-highlight">
                <div class="local-map-widget">
                  <div class="map-header-bar">
                    <span>Contractor near me</span>
                    <span class="map-vol-label">3,142 Monthly Volume</span>
                  </div>
                
                <div class="heatmap-5x5-grid">
                  <!-- Row 1 -->
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  
                  <!-- Row 2 -->
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot orange-dot">8</span>
                  <span class="heatmap-dot orange-dot">8</span>
                  <span class="heatmap-dot orange-dot">6</span>
                  <span class="heatmap-dot orange-dot">8</span>
                  
                  <!-- Row 3 -->
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot orange-dot">7</span>
                  <span class="heatmap-dot green-dot">5</span>
                  <span class="heatmap-dot orange-dot">7</span>
                  
                  <!-- Row 4 -->
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">2</span>
                  
                  <!-- Row 5 -->
                  <span class="heatmap-dot green-dot">3</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot red-dot">×</span>
                  <span class="heatmap-dot green-dot">3</span>
                </div>

                <div class="map-metrics-col">
                  <div class="map-metric-item">
                    <div class="map-metric-pills">
                      <span class="metric-pill-val green-pill">1%</span>
                      <span class="metric-pill-val orange-pill">4%</span>
                      <span class="metric-pill-val red-pill">95%</span>
                    </div>
                    <span class="map-metric-label">Organic</span>
                  </div>

                  <div class="map-metric-item">
                    <div class="map-metric-pills">
                      <span class="metric-pill-val green-pill">1%</span>
                      <span class="metric-pill-val orange-pill">4%</span>
                      <span class="metric-pill-val red-pill">95%</span>
                    </div>
                    <span class="map-metric-label">Maps Ranking</span>
                  </div>
                </div>
              </div>
            </div>
            </div>

            <div class="comparison-column">
              <span class="after-marker-label">After</span>
              <!-- After Card -->
              <div class="visual-comparison-card after-highlight">
                <div class="local-map-widget">
                <div class="map-header-bar">
                  <span>Contractor near me <span style="color: var(--accent);">✦ AI</span></span>
                  <span class="map-vol-label">3,142 Monthly Volume</span>
                </div>
                
                <div class="heatmap-5x5-grid">
                  <!-- Row 1 -->
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">1</span>
                  
                  <!-- Row 2 -->
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">1</span>
                  
                  <!-- Row 3 -->
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">3</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  
                  <!-- Row 4 -->
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                  
                  <!-- Row 5 -->
                  <span class="heatmap-dot green-dot">3</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">2</span>
                  <span class="heatmap-dot green-dot">1</span>
                  <span class="heatmap-dot green-dot">1</span>
                </div>

                <div class="map-metrics-col">
                  <div class="map-metric-item">
                    <div class="map-metric-pills">
                      <span class="metric-pill-val green-pill">100%</span>
                      <span class="metric-pill-val orange-pill">0%</span>
                      <span class="metric-pill-val red-pill">0%</span>
                    </div>
                    <span class="map-metric-label">Organic</span>
                  </div>

                  <div class="map-metric-item">
                    <div class="map-metric-pills">
                      <span class="metric-pill-val green-pill">100%</span>
                      <span class="metric-pill-val orange-pill">0%</span>
                      <span class="metric-pill-val red-pill">0%</span>
                    </div>
                    <span class="map-metric-label">Maps Ranking</span>
                  </div>
                </div>
              </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 3: Get Cited by AI Engines -->
      <div class="comparison-row">
        <!-- Left: description & CTA (transparent column) -->
        <div class="row-info-col">
          <h3 class="row-title">
            <span class="row-title-icon orange-icon">
              <!-- Sparks SVG -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.02 12.02l.707-.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"></path>
              </svg>
            </span>
            Get Cited by AI Engines
          </h3>
          <p class="row-desc">Be the business AI recommends. Get mentioned in ChatGPT and Perplexity—not your competitors.</p>
          <button class="cta-btn-custom orange-btn">
            <!-- Sparks inline icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
            </svg>
            Rank in AI Search
          </button>
        </div>

        <!-- Right: Before/After visuals -->
        <div class="comparison-visuals">
          <div class="cards-comparison-grid">
            <div class="comparison-column">
              <span class="before-marker-label">Before</span>
              <!-- Before Card -->
              <div class="visual-comparison-card before-highlight">
                <div class="serp-results-container">
                  <div class="serp-header">ChatGPT results</div>
                  
                  <div class="chatgpt-prompt-bubble">
                    What are some good restoration contractors near me?
                  </div>

                <div class="chatgpt-response-block">
                  <div class="chatgpt-avatar-wrapper">
                    <!-- OpenAI custom icon -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                  </div>
                  <div class="chatgpt-response-content">
                    <div class="chatgpt-intro-text">
                      Here are some reputable restoration contractors near you in Brighton, Melbourne:
                    </div>
                    <div class="chatgpt-options-list">
                      <!-- Competitor #1 -->
                      <div class="chatgpt-option-item">
                        <span class="chatgpt-option-title">Brighton Restoration Group</span>
                        <span class="chatgpt-option-desc">Specialized in water, fire, and mold restoration.</span>
                      </div>
                      
                      <!-- Your business at #32 -->
                      <div class="chatgpt-option-item highlighted-before">
                        <span class="badge-pill-inline red">Before - Rank #32</span>
                        <span class="chatgpt-option-title">Melbourne Restoration Services</span>
                        <span class="chatgpt-option-desc">Recognized for emergency restoration and 24/7 rapid response.</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            </div>

            <div class="comparison-column">
              <span class="after-marker-label">After</span>
              <!-- After Card -->
              <div class="visual-comparison-card after-highlight">
              <div class="serp-results-container">
                <div class="serp-header">ChatGPT results</div>
                
                <div class="chatgpt-prompt-bubble">
                  What are some good restoration contractors near me?
                </div>

                <div class="chatgpt-response-block">
                  <div class="chatgpt-avatar-wrapper">
                    <!-- OpenAI custom icon -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                  </div>
                  <div class="chatgpt-response-content">
                    <div class="chatgpt-intro-text">
                      Here are some reputable restoration contractors near you in Brighton, Melbourne:
                    </div>
                    <div class="chatgpt-options-list">
                      <!-- Your business citation #1 -->
                      <div class="chatgpt-option-item highlighted-after">
                        <span class="badge-pill-inline green">After - Rank #1</span>
                        <span class="chatgpt-option-title">Melbourne Restoration Services</span>
                        <span class="chatgpt-option-desc">Recognized for emergency restoration and 24/7 rapid response.</span>
                      </div>

                      <!-- Competitor #2 -->
                      <div class="chatgpt-option-item">
                        <span class="chatgpt-option-title">Brighton Restoration Group</span>
                        <span class="chatgpt-option-desc">Specialized in water, fire, and mold restoration.</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
