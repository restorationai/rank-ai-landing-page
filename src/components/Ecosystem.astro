---
import '../styles/global.css';
---

<section id="ecosystem" class="ecosystem-section">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <div class="section-tag-wrapper blue-tag">
        <svg class="section-tag-icon blue-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
          <path d="M12 6v6l4 2"></path>
        </svg>
        <span class="section-tag blue-text">The Rank Ecosystem</span>
      </div>
      <h2>Everything that drives your rank, unified in one system</h2>
      <p class="section-subtitle">A complete growth engine designed specifically for local restoration contractors and home service businesses.</p>
    </div>

    <!-- Grid Container -->
    <div class="ecosystem-grid">
      <!-- Row 1, Col 1: 250-Page Website -->
      <div class="ecosystem-card card-website">
        <div class="ecosystem-card-icon blue-icon">
          <!-- Browser Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="2" y1="10" x2="22" y2="10"></line>
            <circle cx="6" cy="6" r="1"></circle>
            <circle cx="10" cy="6" r="1"></circle>
            <circle cx="14" cy="6" r="1"></circle>
          </svg>
        </div>
        <h3>250-Page Website</h3>
        <p>Custom optimized sites targeting all your local cities.</p>
      </div>

      <!-- Row 1, Col 2: Social Media -->
      <div class="ecosystem-card card-social">
        <div class="ecosystem-card-icon blue-icon">
          <!-- Share/Network Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
        </div>
        <h3>Social Media Citations</h3>
        <p>Automate weekly local citations and social posts to drive ranking signals.</p>
      </div>

      <!-- Row 1, Col 3: Local Rank -->
      <div class="ecosystem-card card-local-rank">
        <div class="ecosystem-card-icon green-icon">
          <!-- Map Pin Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <h3>Local Rank</h3>
        <p>Track and dominate street-by-street Google Maps rankings.</p>
      </div>

      <!-- Row 2, Col 1: AI Receptionist -->
      <div class="ecosystem-card card-receptionist">
        <div class="ecosystem-card-icon blue-icon">
          <!-- Phone/AI Agent Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <h3>AI Receptionist</h3>
        <p>24/7 automated lead capture, qualification, and booking.</p>
      </div>

      <!-- Row 2, Col 2: Center Core Logo -->
      <div class="ecosystem-core-container">
        <div class="ecosystem-core-node">
          <div class="core-logo-inner">
            <span class="core-logo-letter">R</span>
          </div>
          <!-- Decorative pulsing rings -->
          <div class="pulse-ring ring-1"></div>
          <div class="pulse-ring ring-2"></div>
        </div>
      </div>

      <!-- Row 2, Col 3: YouTube Videos -->
      <div class="ecosystem-card card-youtube">
        <div class="ecosystem-card-icon red-icon">
          <!-- Play/YouTube Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
          </svg>
        </div>
        <h3>YouTube Videos</h3>
        <p>Rank in video search results with optimized local content.</p>
      </div>

      <!-- Row 3, Col 1: Blog Posts -->
      <div class="ecosystem-card card-blogs">
        <div class="ecosystem-card-icon blue-icon">
          <!-- Article/Document Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
        </div>
        <h3>Articles with Link Exchange</h3>
        <p>Generate SEO-optimized blog posts and build local authority with link exchanges.</p>
      </div>

      <!-- Row 3, Col 2: Google & Paid Ads -->
      <div class="ecosystem-card card-google-ads">
        <div class="ecosystem-card-icon blue-icon">
          <!-- Google 'G' Icon -->
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114-3.535 0-6.4-2.865-6.4-6.4 0-3.535 2.865-6.4 6.4-6.4 1.582 0 3.026.574 4.143 1.526l3.056-3.056C19.356 2.503 15.992 1 12.24 1 6.168 1 1.24 5.928 1.24 12s4.928 11 11 11c5.786 0 10.286-4.086 10.286-10.286 0-.693-.064-1.36-.186-2H12.24z" />
          </svg>
        </div>
        <h3>Google & Paid Ads</h3>
        <p>Monitor organic rankings and LSA ads in real-time.</p>
      </div>

      <!-- Row 3, Col 3: Unified Analytics -->
      <div class="ecosystem-card card-analytics">
        <div class="ecosystem-card-icon orange-icon">
          <!-- Chart Icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"></line>
            <line x1="12" y1="20" x2="12" y2="4"></line>
            <line x1="6" y1="20" x2="6" y2="14"></line>
          </svg>
        </div>
        <h3>Unified Analytics</h3>
        <p>Track phone calls, lead forms, GBP, and citations in one view.</p>
      </div>
    </div>
  </div>
</section>
