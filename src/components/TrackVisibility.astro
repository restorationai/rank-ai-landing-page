---
import '../styles/global.css';
---

<section id="track-visibility" class="track-visibility-section">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <div class="section-tag-wrapper orange-tag">
        <svg class="section-tag-icon orange-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10"></line>
          <line x1="12" y1="20" x2="12" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="14"></line>
        </svg>
        <span class="section-tag orange-text">AI Search Rank</span>
      </div>
      <h2>Dominate AI Search Results</h2>
      <p class="section-subtitle">We don't just get you to the top of Google. We position your business to be the #1 recommended choice across ChatGPT, Claude, and Perplexity when customers are actively looking for your services.</p>
    </div>

    <!-- Main Dashboard Card -->
    <div class="analytics-dashboard-card">
      <div class="dashboard-header-row">
        <div class="dashboard-tabs">
          <button class="dashboard-tab active">AI Platform Rankings</button>
          <button class="dashboard-tab">Citations by mentioned</button>
        </div>
        <div class="dashboard-controls">
          <div class="toggle-group">
            <button class="toggle-btn"><svg class="control-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><path d="m19 9-5 5-4-4-3 3"></path></svg>Line</button>
            <button class="toggle-btn active"><svg class="control-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><rect x="7" y="10" width="3" height="7" rx="1"></rect><rect x="13" y="6" width="3" height="11" rx="1"></rect><rect x="17" y="12" width="3" height="5" rx="1"></rect></svg>Bar</button>
          </div>
          <button class="select-dropdown">
            <svg class="control-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            This week
            <svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
        </div>
      </div>

      <!-- Platform Metric Chips -->
      <div class="platform-chips-row">
        <!-- ChatGPT -->
        <div class="platform-chip chip-chatgpt">
          <div class="chip-logo-wrapper logo-chatgpt">
            <img src="/chatgpt.png" alt="ChatGPT" class="platform-logo-img" />
          </div>
          <span class="platform-dot dot-chatgpt"></span>
          <span class="chip-name">ChatGPT</span>
          <span class="chip-value">11,815</span>
        </div>

        <!-- Google Gemini -->
        <div class="platform-chip chip-gemini">
          <div class="chip-logo-wrapper logo-gemini">
            <img src="/gemini.png" alt="Google Gemini" class="platform-logo-img" />
          </div>
          <span class="platform-dot dot-gemini"></span>
          <span class="chip-name">Google Gemini</span>
          <span class="chip-value">8,984</span>
        </div>

        <!-- Perplexity AI -->
        <div class="platform-chip chip-perplexity">
          <div class="chip-logo-wrapper logo-perplexity">
            <img src="/perplexity.png" alt="Perplexity AI" class="platform-logo-img" />
          </div>
          <span class="platform-dot dot-perplexity"></span>
          <span class="chip-name">Perplexity AI</span>
          <span class="chip-value">6,103</span>
        </div>

        <!-- Claude -->
        <div class="platform-chip chip-claude">
          <div class="chip-logo-wrapper logo-claude">
            <img src="/claude.png" alt="Claude" class="platform-logo-img" />
          </div>
          <span class="platform-dot dot-claude"></span>
          <span class="chip-name">Claude</span>
          <span class="chip-value">3,979</span>
        </div>
      </div>

      <!-- Segmented Bar Chart Container -->
      <div class="chart-container">
        <!-- Horizontal Grid Lines -->
        <div class="chart-grid-lines">
          <div class="grid-line"></div>
          <div class="grid-line"></div>
          <div class="grid-line"></div>
          <div class="grid-line"></div>
        </div>

        <!-- Columns for each day -->
        <div class="chart-days-row">
          <!-- Mon -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-mon-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-mon-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-mon-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-mon-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 1</span>
          </div>

          <!-- Tue -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-tue-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-tue-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-tue-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-tue-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 2</span>
          </div>

          <!-- Wed -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-wed-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-wed-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-wed-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-wed-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 3</span>
          </div>

          <!-- Thu -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-thu-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-thu-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-thu-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-thu-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 4</span>
          </div>

          <!-- Fri -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-fri-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-fri-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-fri-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-fri-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 5</span>
          </div>

          <!-- Sat -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-sat-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sat-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sat-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sat-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 6</span>
          </div>

          <!-- Sun -->
          <div class="chart-day-group">
            <div class="bar-group">
              <div class="segmented-bar h-sun-1">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sun-2">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sun-3">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
              <div class="segmented-bar h-sun-4">
                <div class="bar-segment chatgpt"></div>
                <div class="bar-segment gemini"></div>
                <div class="bar-segment perplexity"></div>
                <div class="bar-segment claude"></div>
              </div>
            </div>
            <span class="day-label">Month 7</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 4-Column Cards Grid -->
    <div class="insights-grid">
      <!-- AI Recommendation Engine -->
      <div class="insight-card">
        <div class="insight-card-header">
          <div class="insight-icon-wrapper orange-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a10 10 0 1 0 10 10H12V2z"></path>
              <path d="M12 2a10 10 0 0 1 10 10h-10V2z" opacity="0.3"></path>
              <path d="M12 12L2.69 7a10 10 0 0 0 18.62 0L12 12z"></path>
            </svg>
          </div>
          <span class="badge-new">New</span>
        </div>
        <h3>AI Recommendation Engine</h3>
        <p>We optimize your digital presence so AI assistants specifically recommend your business when customers are looking for your services.</p>
        <a href="#calendar" class="learn-more-link" data-modal-target="ai-recommendation-engine" data-modal-title="AI Recommendation Engine" data-modal-desc="We optimize your entire digital ecosystem specifically for AI parsing. When local homeowners ask ChatGPT or Claude for immediate restoration help, our backend tuning ensures your business is cited as the highest-authority, most trusted local option. Stop losing jobs to competitors just because AI couldn't read your site.">
          Learn More 
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Smart Citation Building -->
      <div class="insight-card">
        <div class="insight-card-header">
          <div class="insight-icon-wrapper orange-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <span class="badge-new">New</span>
        </div>
        <h3>Smart Citation Building</h3>
        <p>We feed the exact data sources that train LLMs (Large Language Models), ensuring AI platforms have the right context to trust and recommend you.</p>
        <a href="#calendar" class="learn-more-link" data-modal-target="smart-citation-building" data-modal-title="Smart Citation Building" data-modal-desc="LLMs like ChatGPT don't search the web like Google does; they rely on massive datasets and specific high-authority directories. We inject your business data directly into the exact data pipelines and reference nodes that train these AI models, guaranteeing your business is etched into their baseline knowledge.">
          Learn More 
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Massive Content Strategy -->
      <div class="insight-card">
        <div class="insight-card-header">
          <div class="insight-icon-wrapper green-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
        </div>
        <h3>Massive Content Strategy</h3>
        <p>We build high-volume, targeted content and weekly resources to ensure you have the depth of information AI models require to view you as the local authority.</p>
        <a href="#calendar" class="learn-more-link" data-modal-target="massive-content-strategy" data-modal-title="Massive Content Strategy" data-modal-desc="Thin websites get ignored by AI. We deploy a massive, 250+ page content architecture and continuously publish hyper-relevant, geo-targeted blog posts. This sheer volume of structured data forces AI models to recognize you as the definitive local expert, driving higher trust scores and more recommendations.">
          Learn More 
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Weekly AI Tracking Autopilot -->
      <div class="insight-card">
        <div class="insight-card-header">
          <div class="insight-icon-wrapper purple-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <span class="badge-new">New</span>
        </div>
        <h3>Weekly Tracking Autopilot</h3>
        <p>Our platform tracks your ranking movements on ChatGPT and Perplexity weekly, automatically adjusting our strategy to keep you at the top.</p>
        <a href="#calendar" class="learn-more-link" data-modal-target="weekly-tracking-autopilot" data-modal-title="Weekly Tracking Autopilot" data-modal-desc="You can't manage what you don't measure. Our proprietary dashboard monitors your business mentions across every major AI platform in real-time. We track exactly how often you are recommended and automatically adjust your content strategy weekly to ensure you never lose the #1 spot to a competitor.">
          Learn More 
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
