        <div class="keywords-filter-container">
          <span class="keywords-label">Keywords:</span>
          <div class="keyword-pills">
            <span class="keyword-pill active">
              water damage restoration <span class="pill-rank-badge">#1</span>
            </span>
            <span class="keyword-pill">
