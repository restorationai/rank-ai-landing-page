              </svg>
              <div class="radial-gauge-text">
                <span class="gauge-val-num">3,142</span>
                <span class="gauge-label-top">Monthly Volume</span>
              </div>
            </div>
            <span class="gauge-keyword-name">water damage restoration</span>
