<section id="local-search" class="local-search-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag-wrapper orange-tag">
        <svg class="section-tag-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <line x1="18" y1="20" x2="18" y2="10" stroke-linecap="round"/>
          <line x1="12" y1="20" x2="12" y2="4" stroke-linecap="round"/>
          <line x1="6" y1="20" x2="6" y2="14" stroke-linecap="round"/>
        </svg>
        <span class="section-tag">LOCAL SEO</span>
      </div>
      <h2>Dominate Local Search Results</h2>
      <p class="section-subtitle">
        Track your local Google Maps rankings in each city to make sure your company is the first contractor homeowners see.
      </p>
