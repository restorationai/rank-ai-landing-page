<script>
  // Peak values for each channel
  const PEAK_VALUES = {
    youtube: 110000,
    linkedin: 85000,
    'x-com': 140000,
    'social-citations': 185435,
    blog: 200000
  };

  // State of which channels are active
  let activeChannels = {
    youtube: true,
    linkedin: true,
    'x-com': true,
    'social-citations': true,
    blog: true
  };

  // Active chart type ('line' or 'bar')
  let chartType = 'line';

  // DOM Elements
  const viewsCounter = document.getElementById('content-views-counter');
  const pills = document.querySelectorAll('.channel-pill');
  const toggleLine = document.getElementById('chart-toggle-line');
  const toggleBar = document.getElementById('chart-toggle-bar');
  const linesGroup = document.getElementById('chart-group-lines');
  const barsGroup = document.getElementById('chart-group-bars');

  // Value formatting function
  function formatNumber(num) {
    return new Intl.NumberFormat('en-US').format(num);
  }

  // Update cumulative views counter with micro-animation
  function updateViewsCounter() {
    if (!viewsCounter) return;
    
    // Sum active peak values
    let total = 0;
    Object.keys(activeChannels).forEach(channel => {
      if (activeChannels[channel]) {
        total += PEAK_VALUES[channel];
      }
    });

    const startVal = parseInt(viewsCounter.textContent.replace(/,/g, '')) || 0;
    const duration = 400; // ms
    const startTime = performance.now();

    function animate(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      // Easing out quad
      const easeProgress = progress * (2 - progress);
      const currentVal = Math.round(startVal + (total - startVal) * easeProgress);
      
      viewsCounter.textContent = formatNumber(currentVal);

      if (progress < 1) {
        requestAnimationFrame(animate);
      }
    }

    requestAnimationFrame(animate);
  }

  // Toggle active lines/dots/bars based on channel state
  function updateChartVisibility() {
    // 1. Line chart elements
    Object.keys(activeChannels).forEach(channel => {
      const line = document.getElementById(`line-${channel}`);
      const area = document.getElementById(`area-${channel}`);
      const dots = document.getElementById(`dots-${channel}`);
      const isActive = activeChannels[channel];

      if (line) {
        line.style.opacity = isActive ? '1' : '0';
        line.style.pointerEvents = isActive ? 'auto' : 'none';
      }
      if (area) {
        area.style.opacity = isActive ? '0.05' : '0';
      }
      if (dots) {
        dots.style.opacity = isActive ? '1' : '0';
        dots.style.pointerEvents = isActive ? 'auto' : 'none';
      }

      // 2. Bar chart elements (7 weeks, each has a bar for this channel)
      for (let week = 1; week <= 7; week++) {
        const barElement = document.getElementById(`bar-${week}-${channel}`);
        if (barElement) {
          barElement.style.opacity = isActive ? '1' : '0';
          barElement.style.pointerEvents = isActive ? 'auto' : 'none';
        }
      }
    });
  }

  // Set up Channel pill click listeners
  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const channel = pill.getAttribute('data-channel');
      if (!channel) return;

      // Toggle state
      activeChannels[channel] = !activeChannels[channel];
      
      // Toggle class
      pill.classList.toggle('active');

      // Update UI
      updateViewsCounter();
      updateChartVisibility();
    });
  });

  // Toggle between Line and Bar charts
  function setChartType(type) {
    chartType = type;
    if (type === 'line') {
      toggleLine?.classList.add('active');
      toggleBar?.classList.remove('active');
      if (linesGroup) linesGroup.style.display = 'block';
      if (barsGroup) barsGroup.style.display = 'none';
    } else {
      toggleLine?.classList.remove('active');
      toggleBar?.classList.add('active');
      if (linesGroup) linesGroup.style.display = 'none';
      if (barsGroup) barsGroup.style.display = 'block';
    }
  }

  toggleLine?.addEventListener('click', () => setChartType('line'));
  toggleBar?.addEventListener('click', () => setChartType('bar'));

  // Initialize
  updateViewsCounter();
  updateChartVisibility();
</script>
