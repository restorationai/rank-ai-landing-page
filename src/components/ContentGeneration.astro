---
---
<section class="content-gen-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag-wrapper content-tag">
        <svg class="section-tag-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10"></line>
          <line x1="12" y1="20" x2="12" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="14"></line>
        </svg>
        <span class="section-tag">CONTENT STRATEGY</span>
      </div>
      <h2>Generate Content That Helps You Rank</h2>
      <p class="section-subtitle">
        Scale local authority with automated SEO-optimized blog posts, citation networks, and multi-channel citation strategies.
      </p>
    </div>

    <!-- Interactive Dashboard Mockup Card -->
    <div class="content-dashboard-card">
      <div class="content-dashboard-header">
        <div class="content-dashboard-title-area">
          <h4>Multi-Channel Content Performance</h4>
          <div class="views-display-row">
            <span class="content-dashboard-views-value" id="content-views-counter">720,435</span>
            <span class="content-dashboard-subtitle">Weekly Views</span>
          </div>
        </div>

        <div class="content-dashboard-controls">
          <!-- Channel Filters -->
          <div class="channel-filters">
            <button class="channel-pill youtube active" data-channel="youtube">
              <span class="pill-icon" style="color: #ef4444;">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </span>
              YouTube
            </button>
            <button class="channel-pill linkedin active" data-channel="linkedin">
              <span class="pill-icon" style="color: #0077b5;">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
                </svg>
              </span>
              LinkedIn
            </button>
            <button class="channel-pill x-com active" data-channel="x-com">
              <span class="pill-icon" style="color: #0f1419;">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </span>
              X.com
            </button>
            <button class="channel-pill social-citations active" data-channel="social-citations">
              <span class="pill-icon" style="color: #10b981;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                </svg>
              </span>
              GBP Posts
            </button>
            <button class="channel-pill blog active" data-channel="blog">
              <span class="pill-icon" style="color: #0d9488;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              </span>
              Blog
            </button>
          </div>

          <div class="divider-vertical"></div>

          <!-- Line/Bar Chart Toggle -->
          <div class="chart-type-toggle">
            <button class="toggle-option active" id="chart-toggle-line">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"></path>
                <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
              </svg>
              Line
            </button>
            <button class="toggle-option" id="chart-toggle-bar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 20V10"></path>
                <path d="M12 20V4"></path>
                <path d="M6 20v-6"></path>
              </svg>
              Bar
            </button>
          </div>
        </div>
      </div>

      <!-- SVG Chart Area -->
      <div class="chart-container-line">
        <svg class="chart-svg" viewBox="0 0 800 300" preserveAspectRatio="none">
          <defs>
            <!-- Gradients for area shading under paths -->
            <linearGradient id="grad-youtube" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#ef4444" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#ef4444" stop-opacity="0.00"></stop>
            </linearGradient>
            <linearGradient id="grad-linkedin" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.00"></stop>
            </linearGradient>
            <linearGradient id="grad-x-com" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#111827" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#111827" stop-opacity="0.00"></stop>
            </linearGradient>
            <linearGradient id="grad-social-citations" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#10b981" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#10b981" stop-opacity="0.00"></stop>
            </linearGradient>
            <linearGradient id="grad-blog" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#0d9488" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#0d9488" stop-opacity="0.00"></stop>
            </linearGradient>
          </defs>

          <!-- Horizontal Grid Lines -->
          <line class="chart-grid-line" x1="60" y1="30" x2="760" y2="30"></line>
          <line class="chart-grid-line" x1="60" y1="87.5" x2="760" y2="87.5"></line>
          <line class="chart-grid-line" x1="60" y1="145" x2="760" y2="145"></line>
          <line class="chart-grid-line" x1="60" y1="202.5" x2="760" y2="202.5"></line>
          <line class="chart-grid-line" x1="60" y1="260" x2="760" y2="260"></line>

          <!-- Y-Axis Labels -->
          <text class="chart-axis-text" x="50" y="34" text-anchor="end">75k</text>
          <text class="chart-axis-text" x="50" y="91.5" text-anchor="end">50k</text>
          <text class="chart-axis-text" x="50" y="149" text-anchor="end">25k</text>
          <text class="chart-axis-text" x="50" y="206.5" text-anchor="end">10k</text>
          <text class="chart-axis-text" x="50" y="264" text-anchor="end">0</text>

          <!-- X-Axis Labels -->
          <text class="chart-axis-text" x="80" y="285" text-anchor="middle">Mon</text>
          <text class="chart-axis-text" x="193.3" y="285" text-anchor="middle">Tue</text>
          <text class="chart-axis-text" x="306.6" y="285" text-anchor="middle">Wed</text>
          <text class="chart-axis-text" x="420" y="285" text-anchor="middle">Thu</text>
          <text class="chart-axis-text" x="533.3" y="285" text-anchor="middle">Fri</text>
          <text class="chart-axis-text" x="646.6" y="285" text-anchor="middle">Sat</text>
          <text class="chart-axis-text" x="760" y="285" text-anchor="middle">Sun</text>

          <!-- Group for Line Chart elements -->
          <g id="chart-group-lines">
            <!-- YouTube (Red) -->
            <path class="chart-area-shading" id="area-youtube" fill="url(#grad-youtube)" d="M 80 260 L 80 260 L 193.3 215 L 306.6 165 L 420 155 L 533.3 65 L 646.6 85 L 760 68 L 760 260 Z"></path>
            <path class="chart-line-path" id="line-youtube" stroke="#ef4444" d="M 80 260 L 193.3 215 L 306.6 165 L 420 155 L 533.3 65 L 646.6 85 L 760 68"></path>

            <!-- LinkedIn (Blue) -->
            <path class="chart-area-shading" id="area-linkedin" fill="url(#grad-linkedin)" d="M 80 260 L 80 260 L 193.3 202.5 L 306.6 185 L 420 150 L 533.3 170 L 646.6 90 L 760 110 L 760 260 Z"></path>
            <path class="chart-line-path" id="line-linkedin" stroke="#3b82f6" d="M 80 260 L 193.3 202.5 L 306.6 185 L 420 150 L 533.3 170 L 646.6 90 L 760 110"></path>

            <!-- X.com (Black) -->
            <path class="chart-area-shading" id="area-x-com" fill="url(#grad-x-com)" d="M 80 260 L 80 260 L 193.3 185 L 306.6 175 L 420 165 L 533.3 95 L 646.6 60 L 760 75 L 760 260 Z"></path>
            <path class="chart-line-path" id="line-x-com" stroke="#111827" d="M 80 260 L 193.3 185 L 306.6 175 L 420 165 L 533.3 95 L 646.6 60 L 760 75"></path>

            <!-- GBP Posts (Green) -->
            <path class="chart-area-shading" id="area-social-citations" fill="url(#grad-social-citations)" d="M 80 260 L 80 260 L 193.3 170 L 306.6 155 L 420 170 L 533.3 115 L 646.6 95 L 760 100 L 760 260 Z"></path>
            <path class="chart-line-path" id="line-social-citations" stroke="#10b981" d="M 80 260 L 193.3 170 L 306.6 155 L 420 170 L 533.3 115 L 646.6 95 L 760 100"></path>

            <!-- Blog (Teal) -->
            <path class="chart-area-shading" id="area-blog" fill="url(#grad-blog)" d="M 80 260 L 80 260 L 193.3 230 L 306.6 225 L 420 190 L 533.3 145 L 646.6 145 L 760 135 L 760 260 Z"></path>
            <path class="chart-line-path" id="line-blog" stroke="#0d9488" d="M 80 260 L 193.3 230 L 306.6 225 L 420 190 L 533.3 145 L 646.6 145 L 760 135"></path>

            <!-- Vertices/Dots for YouTube -->
            <g class="dots-group" id="dots-youtube">
              <circle class="chart-dot" stroke="#ef4444" cx="80" cy="260" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="193.3" cy="215" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="306.6" cy="165" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="420" cy="155" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="533.3" cy="65" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="646.6" cy="85" r="4.5"></circle>
              <circle class="chart-dot" stroke="#ef4444" cx="760" cy="68" r="4.5"></circle>
            </g>

            <!-- Vertices/Dots for LinkedIn -->
            <g class="dots-group" id="dots-linkedin">
              <circle class="chart-dot" stroke="#3b82f6" cx="80" cy="260" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="193.3" cy="202.5" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="306.6" cy="185" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="420" cy="150" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="533.3" cy="170" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="646.6" cy="90" r="4.5"></circle>
              <circle class="chart-dot" stroke="#3b82f6" cx="760" cy="110" r="4.5"></circle>
            </g>

            <!-- Vertices/Dots for X.com -->
            <g class="dots-group" id="dots-x-com">
              <circle class="chart-dot" stroke="#111827" cx="80" cy="260" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="193.3" cy="185" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="306.6" cy="175" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="420" cy="165" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="533.3" cy="95" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="646.6" cy="60" r="4.5"></circle>
              <circle class="chart-dot" stroke="#111827" cx="760" cy="75" r="4.5"></circle>
            </g>

            <!-- Vertices/Dots for GBP Posts -->
            <g class="dots-group" id="dots-social-citations">
              <circle class="chart-dot" stroke="#10b981" cx="80" cy="260" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="193.3" cy="170" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="306.6" cy="155" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="420" cy="170" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="533.3" cy="115" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="646.6" cy="95" r="4.5"></circle>
              <circle class="chart-dot" stroke="#10b981" cx="760" cy="100" r="4.5"></circle>
            </g>

            <!-- Vertices/Dots for Blog -->
            <g class="dots-group" id="dots-blog">
              <circle class="chart-dot" stroke="#0d9488" cx="80" cy="260" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="193.3" cy="230" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="306.6" cy="225" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="420" cy="190" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="533.3" cy="145" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="646.6" cy="145" r="4.5"></circle>
              <circle class="chart-dot" stroke="#0d9488" cx="760" cy="135" r="4.5"></circle>
            </g>
          </g>

          <!-- Group for Bar Chart elements (hidden by default) -->
          <g id="chart-group-bars" style="display: none;">
            <!-- Grouped bars per week. 7 weeks. Each active channel gets a thin rect within the week segment. -->
            <!-- Week 1: Mon -->
            <g class="bar-week" data-week="1">
              <rect class="chart-bar" id="bar-1-youtube" fill="#ef4444" x="60" y="258" width="6" height="2" rx="1"></rect>
              <rect class="chart-bar" id="bar-1-linkedin" fill="#3b82f6" x="68" y="258" width="6" height="2" rx="1"></rect>
              <rect class="chart-bar" id="bar-1-x-com" fill="#111827" x="76" y="258" width="6" height="2" rx="1"></rect>
              <rect class="chart-bar" id="bar-1-social-citations" fill="#10b981" x="84" y="258" width="6" height="2" rx="1"></rect>
              <rect class="chart-bar" id="bar-1-blog" fill="#0d9488" x="92" y="258" width="6" height="2" rx="1"></rect>
            </g>
            <!-- Week 2: Tue -->
            <g class="bar-week" data-week="2">
              <rect class="chart-bar" id="bar-2-youtube" fill="#ef4444" x="173.3" y="215" width="6" height="45" rx="1"></rect>
              <rect class="chart-bar" id="bar-2-linkedin" fill="#3b82f6" x="181.3" y="202.5" width="6" height="57.5" rx="1"></rect>
              <rect class="chart-bar" id="bar-2-x-com" fill="#111827" x="189.3" y="185" width="6" height="75" rx="1"></rect>
              <rect class="chart-bar" id="bar-2-social-citations" fill="#10b981" x="197.3" y="170" width="6" height="90" rx="1"></rect>
              <rect class="chart-bar" id="bar-2-blog" fill="#0d9488" x="205.3" y="230" width="6" height="30" rx="1"></rect>
            </g>
            <!-- Week 3: Wed -->
            <g class="bar-week" data-week="3">
              <rect class="chart-bar" id="bar-3-youtube" fill="#ef4444" x="286.6" y="165" width="6" height="95" rx="1"></rect>
              <rect class="chart-bar" id="bar-3-linkedin" fill="#3b82f6" x="294.6" y="185" width="6" height="75" rx="1"></rect>
              <rect class="chart-bar" id="bar-3-x-com" fill="#111827" x="302.6" y="175" width="6" height="85" rx="1"></rect>
              <rect class="chart-bar" id="bar-3-social-citations" fill="#10b981" x="310.6" y="155" width="6" height="105" rx="1"></rect>
              <rect class="chart-bar" id="bar-3-blog" fill="#0d9488" x="318.6" y="225" width="6" height="35" rx="1"></rect>
            </g>
            <!-- Week 4: Thu -->
            <g class="bar-week" data-week="4">
              <rect class="chart-bar" id="bar-4-youtube" fill="#ef4444" x="400" y="155" width="6" height="105" rx="1"></rect>
              <rect class="chart-bar" id="bar-4-linkedin" fill="#3b82f6" x="408" y="150" width="6" height="110" rx="1"></rect>
              <rect class="chart-bar" id="bar-4-x-com" fill="#111827" x="416" y="165" width="6" height="95" rx="1"></rect>
              <rect class="chart-bar" id="bar-4-social-citations" fill="#10b981" x="424" y="170" width="6" height="90" rx="1"></rect>
              <rect class="chart-bar" id="bar-4-blog" fill="#0d9488" x="432" y="190" width="6" height="70" rx="1"></rect>
            </g>
            <!-- Week 5: Fri -->
            <g class="bar-week" data-week="5">
              <rect class="chart-bar" id="bar-5-youtube" fill="#ef4444" x="513.3" y="65" width="6" height="195" rx="1"></rect>
              <rect class="chart-bar" id="bar-5-linkedin" fill="#3b82f6" x="521.3" y="170" width="6" height="90" rx="1"></rect>
              <rect class="chart-bar" id="bar-5-x-com" fill="#111827" x="529.3" y="95" width="6" height="165" rx="1"></rect>
              <rect class="chart-bar" id="bar-5-social-citations" fill="#10b981" x="537.3" y="115" width="6" height="145" rx="1"></rect>
              <rect class="chart-bar" id="bar-5-blog" fill="#0d9488" x="545.3" y="145" width="6" height="115" rx="1"></rect>
            </g>
            <!-- Week 6: Sat -->
            <g class="bar-week" data-week="6">
              <rect class="chart-bar" id="bar-6-youtube" fill="#ef4444" x="626.6" y="85" width="6" height="175" rx="1"></rect>
              <rect class="chart-bar" id="bar-6-linkedin" fill="#3b82f6" x="634.6" y="90" width="6" height="170" rx="1"></rect>
              <rect class="chart-bar" id="bar-6-x-com" fill="#111827" x="642.6" y="60" width="6" height="200" rx="1"></rect>
              <rect class="chart-bar" id="bar-6-social-citations" fill="#10b981" x="650.6" y="95" width="6" height="165" rx="1"></rect>
              <rect class="chart-bar" id="bar-6-blog" fill="#0d9488" x="658.6" y="145" width="6" height="115" rx="1"></rect>
            </g>
            <!-- Week 7: Sun -->
            <g class="bar-week" data-week="7">
              <rect class="chart-bar" id="bar-7-youtube" fill="#ef4444" x="740" y="68" width="6" height="192" rx="1"></rect>
              <rect class="chart-bar" id="bar-7-linkedin" fill="#3b82f6" x="748" y="110" width="6" height="150" rx="1"></rect>
              <rect class="chart-bar" id="bar-7-x-com" fill="#111827" x="756" y="75" width="6" height="185" rx="1"></rect>
              <rect class="chart-bar" id="bar-7-social-citations" fill="#10b981" x="764" y="100" width="6" height="160" rx="1"></rect>
              <rect class="chart-bar" id="bar-7-blog" fill="#0d9488" x="772" y="135" width="6" height="125" rx="1"></rect>
            </g>
          </g>
        </svg>
      </div>

      <!-- Dashboard Separator Line -->
      <div class="dashboard-separator"></div>

      <!-- Feature Cards Grid (4 Columns) inside the dashboard card container -->
      <div class="content-cards-grid">
        <!-- Card 1: Articles with Link Exchange -->
        <div class="content-feat-card">
          <div class="card-header-inline">
            <span class="mini-badge badge-articles">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
              </svg>
            </span>
            <h3>Articles with Link Exchange</h3>
          </div>
          <p>Deploy SEO-optimized blog posts built for conversion. Our link exchange network builds backlink authority automatically.</p>
          <a href="#" class="content-card-cta">
            Learn More
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>

        <!-- Card 2: Social Media Citations -->
        <div class="content-feat-card">
          <div class="card-header-inline">
            <span class="mini-badge badge-social">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
              </svg>
            </span>
