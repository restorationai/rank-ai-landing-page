<section class="pricing-section section-dark" id="pricing">
  <div class="container">
    <div class="section-header text-center">
      <h2 class="gradient-text">Simple, All-Inclusive Pricing</h2>
      <p class="section-subtitle">Everything you need to dominate local and AI search, bundled into one powerful platform.</p>
    </div>

    <div class="pricing-card-wrapper">
      <div class="pricing-card premium-glow">
        <div class="pricing-header">
          <h3>The Rank AI Growth Engine</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">997</span>
            <span class="period">/ month</span>
          </div>
          <p class="pricing-desc">No long-term contracts. No hidden fees.</p>
        </div>
        
        <div class="pricing-body">
          <ul class="feature-list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Brand New 250-Page Custom Website</strong> built for conversions</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Complete Local SEO</strong> & Google Business Profile Management</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>AI Search Optimization</strong> (ChatGPT, Gemini, Claude)</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Targeted Blogs, FAQs & YouTube Videos</strong> with JSON-LD schema</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Google LSA & PPC Management</strong> to eliminate wasted ad spend</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>24/7 AI Receptionist</strong> & dynamic call tracking</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Full Analytics Dashboard</strong> with real-time Geo-Grid rankings</span>
            </li>
          </ul>
        </div>

        <div class="pricing-footer">
          <a href="#audit" class="btn btn-primary btn-large w-full" style="justify-content: center;">Start Dominating Today</a>
        </div>
      </div>
    </div>
  </div>
</section>
